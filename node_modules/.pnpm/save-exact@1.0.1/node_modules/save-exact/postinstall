#!/bin/bash

# If anyone wants this package name for a more... useful purpose, let me know.
# I'm incredibly surprised how many installs this gets.

set -euo pipefail

dragon() {
  ./node_modules/.bin/cowsay -f dragon -W 60 $@
}

main() {
  sleep 2
  dragon Hey there
  sleep 2
  dragon Looks like you accidentally installed a package called \"save-exact\"
  sleep 4
  dragon You probably want \"--save-exact\" instead
  sleep 3
  dragon Making typos in package names can be dangerous - packages can run scripts on your computer! Like this one!
  sleep 4
  dragon They can even access your files! Like that file I just put on your desktop!
  dragon Yeah, this one! >> ~/Desktop/psst.txt
  sleep 4
  dragon That\'s all for now. Be careful out there!
}

main "$@"
